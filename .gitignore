# Python bytecode and interpreter artifacts
__pycache__/
*.py[cod]
*$py.class
*.pyd

# Virtual environments
.venv/
venv/
env/
ENV/
.direnv/

# Distribution and packaging
*.egg-info/
.eggs/
pip-wheel-metadata/
dist/
build/
wheelhouse/
*.whl
*.tar.gz

# Test, coverage, lint, and type-checker state
.pytest_cache/
.hypothesis/
.tox/
.nox/
.mypy_cache/
.pyre/
.pytype/
.ruff_cache/
.cache/
.coverage
.coverage.*
coverage.xml
coverage.json
htmlcov/
test-results/
junit*.xml
pytestdebug.log
.dmypy.json
dmypy.json

# Editors and local agent state
.vscode/
.idea/
.codex/
*.swp
*.swo
*~

# Local environment and secrets
.env
.env.*
!.env.example
!.env.template

# Operating-system and crash artifacts
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store
*.dmp
*.stackdump

# Logs
logs/
*.log

# Workbook backups and snapshots (user-generated, not tracked)
backups/
snapshots/
.snapshots/
workbook/backups/
workbook/snapshots/

# Screenshots and dumps (generated artifacts)
docs/screenshots/
docs/dumps/
screenshots/
dump.json
dump.md

# Excel workbooks (ignored by default to prevent repository pollution)
~$*.xls*
*.xlsm
*.xlsx
*.xls
*.xlsb
sample_workbooks/

# Allow intentionally reviewed, small binary fixtures only under tests/fixtures.
!tests/fixtures/*.xlsm
!tests/fixtures/*.xlsx
!tests/fixtures/*.xls
!tests/fixtures/*.xlsb
!tests/fixtures/**/*.xlsm
!tests/fixtures/**/*.xlsx
!tests/fixtures/**/*.xls
!tests/fixtures/**/*.xlsb
