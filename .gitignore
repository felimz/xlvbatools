# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
ENV/

# Distribution / packaging
*.egg-info/
dist/
build/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
Thumbs.db
.DS_Store

# Logs
logs/
*.log

# Test artifacts
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
.coverage.*

# Workbook backups and snapshots (user-generated, not tracked)
backups/
snapshots/
.snapshots/
workbook/backups/
workbook/snapshots/

# Screenshots and dumps (generated artifacts)
docs/screenshots/
docs/dumps/
screenshots/
dump.json
dump.md

# Excel workbooks (ignored by default to prevent repository pollution)
*.xlsm
*.xlsx
*.xls
*.xlsb
sample_workbooks/

# Allow tracking tiny standard test fixtures explicitly if needed
!tests/fixtures/*.xlsm
!tests/fixtures/*.xlsx
